# [ZH] 本文件是 single-work-analysis 的环境变量示例。
# [EN] This file is the env example for single-work-analysis.
#
# [ZH] 正常情况下，请先把仓库根 env.example 复制到 skills/.env。
# [EN] In normal use, copy the repo-root env.example to skills/.env first.
#
# [ZH] 只有当 single-work-analysis 需要局部覆盖时，才把下面字段复制到本目录的 .env.local。
# [EN] Only copy selected keys into this folder's .env.local when single-work-analysis needs local overrides.

# [ZH] 输出根目录。默认值：继承 skills/.env；如需局部覆盖，必须是绝对路径。
# [EN] Output root. Default: inherited from skills/.env; must be absolute when overridden locally.
# TIKOMNI_OUTPUT_ROOT="/absolute/path/to/tikomni-output"

# [ZH] 卡片根目录。默认值：继承 skills/.env；如需局部覆盖，必须是绝对路径。
# [EN] Card root. Default: inherited from skills/.env; must be absolute when overridden locally.
# TIKOMNI_CARD_ROOT="/absolute/path/to/tikomni-cards"

# [ZH] 路由语言预设。默认值：zh
# [EN] Route locale preset. Default: zh
TIKOMNI_PATH_LOCALE="zh"

# [ZH] 作品卡文件名前缀。默认值：CBV
# [EN] Work card filename prefix. Default: CBV
TIKOMNI_CARD_PREFIX_WORK="CBV"

# [ZH] 卡片文件名模板。默认值：{prefix}-{platform}-{author_slug}-{title_slug}{ext}
# [EN] Card filename pattern. Default: {prefix}-{platform}-{author_slug}-{title_slug}{ext}
TIKOMNI_FILENAME_PATTERN_CARD="{prefix}-{platform}-{author_slug}-{title_slug}{ext}"

# [ZH] JSON 文件名模板。默认值：{timestamp}-{platform}-{identifier}{ext}
# [EN] JSON filename pattern. Default: {timestamp}-{platform}-{identifier}{ext}
TIKOMNI_FILENAME_PATTERN_JSON="{timestamp}-{platform}-{identifier}{ext}"

# [ZH] 显式配置文件路径。默认值：空；留空时自动使用本模块 defaults.yaml
# [EN] Explicit config file path. Default: empty; when empty the module uses its own defaults.yaml
# TIKOMNI_CONFIG_FILE=""
