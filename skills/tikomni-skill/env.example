# Tikomni Skill Environment Template
# Copy this file to <workspace_root>/.env or skills/tikomni-skill/.env.local
# Then replace placeholder values with real values.
# Never commit real secrets.

# =====================
# Required (must set)
# =====================
TIKOMNI_API_KEY="tk_example_replace_me"

# =========================================
# Optional Advanced (all have safe defaults)
# =========================================

# Request timeout in milliseconds (default: 60000)
# TIKOMNI_TIMEOUT_MS="60000"

# Output directories (defaults: docs/skill-output, _runs, results, _errors)
# TIKOMNI_OUTPUT_ROOT="docs/skill-output"
# TIKOMNI_OUTPUT_RUNS_DIR="_runs"
# TIKOMNI_OUTPUT_RESULTS_DIR="results"
# TIKOMNI_OUTPUT_ERRORS_DIR="_errors"

# Filename pattern for non-card outputs (default: {type}-{timestamp}-{job_id}.md)
# TIKOMNI_FILENAME_PATTERN="{type}-{timestamp}-{job_id}.md"

# Route locale preset for card directories: zh | en (default: zh)
# TIKOMNI_PATH_LOCALE="zh"

# Explicit card routes (highest priority; use "|" as path separator)
# TIKOMNI_CARD_ROUTE_WORK="10-内容系统|15-对标研究|01-作品对标卡"
# TIKOMNI_CARD_ROUTE_AUTHOR="10-内容系统|15-对标研究|03-作者对标卡"
# TIKOMNI_CARD_ROUTE_AUTHOR_SAMPLE_WORK="10-内容系统|15-对标研究|02-作者样本集|{platform}-{author_slug}"

# Optional HTTP header overrides
# TIKOMNI_HTTP_USER_AGENT="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/123.0.0.0 Safari/537.36"
# TIKOMNI_HTTP_ACCEPT_LANGUAGE="zh-CN,zh;q=0.9,en;q=0.8"
