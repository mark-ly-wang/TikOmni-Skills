# [ZH] 本文件是 creator-analysis 的环境变量示例。
# [EN] This file is the env example for creator-analysis.
#
# [ZH] 正常情况下，请先把仓库根 env.example 复制到 skills/.env。
# [EN] In normal use, copy the repo-root env.example to skills/.env first.
#
# [ZH] 只有当 creator-analysis 需要局部覆盖时，才把下面字段复制到本目录的 .env.local。
# [EN] Only copy selected keys into this folder's .env.local when creator-analysis needs local overrides.

# [ZH] 输出根目录。默认值：继承 skills/.env；如需局部覆盖，必须是绝对路径。
# [EN] Output root. Default: inherited from skills/.env; must be absolute when overridden locally.
# TIKOMNI_OUTPUT_ROOT="/absolute/path/to/tikomni-output"

# [ZH] 卡片根目录。默认值：继承 skills/.env；如需局部覆盖，必须是绝对路径。
# [EN] Card root. Default: inherited from skills/.env; must be absolute when overridden locally.
# TIKOMNI_CARD_ROOT="/absolute/path/to/tikomni-cards"

# [ZH] 路由语言预设。默认值：zh
# [EN] Route locale preset. Default: zh
TIKOMNI_PATH_LOCALE="zh"

# [ZH] 作者级 LLM 分析超时，单位秒。默认值：45
# [EN] Timeout for creator-level LLM analysis in seconds. Default: 45
TIKOMNI_AUTHOR_ANALYSIS_TIMEOUT_SEC="45"

# [ZH] sampled works 少于该阈值时跳过作者级 LLM 分析。默认值：5
# [EN] Skip creator-level LLM analysis when sampled works are below this threshold. Default: 5
TIKOMNI_AUTHOR_ANALYSIS_SMALL_SAMPLE_SKIP="5"

# [ZH] sampled works 批量解释超时，单位秒。默认值：45
# [EN] Timeout for sampled-work batch explanations in seconds. Default: 45
TIKOMNI_SAMPLED_EXPLANATION_TIMEOUT_SEC="45"

# [ZH] 显式配置文件路径。默认值：空；留空时自动使用本模块 defaults.yaml
# [EN] Explicit config file path. Default: empty; when empty the module uses its own defaults.yaml
# TIKOMNI_CONFIG_FILE=""
