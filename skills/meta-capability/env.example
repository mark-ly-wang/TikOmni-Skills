# [ZH] 本文件是 meta-capability 的环境变量示例。
# [EN] This file is the env example for meta-capability.
#
# [ZH] 正常情况下，请先把仓库根 env.example 复制到 skills/.env。
# [EN] In normal use, copy the repo-root env.example to skills/.env first.
#
# [ZH] 只有当 meta-capability 需要局部覆盖时，才把下面字段复制到本目录的 .env.local。
# [EN] Only copy selected keys into this folder's .env.local when meta-capability needs local overrides.

# [ZH] TikOmni API 基础地址。默认值：https://api.tikomni.com
# [EN] TikOmni API base URL. Default: https://api.tikomni.com
TIKOMNI_BASE_URL="https://api.tikomni.com"

# [ZH] HTTP 请求超时，单位毫秒。默认值：60000
# [EN] HTTP request timeout in milliseconds. Default: 60000
TIKOMNI_TIMEOUT_MS="60000"

# [ZH] 全局请求 QPS 节流。默认值：5.0
# [EN] Global request QPS throttle. Default: 5.0
TIKOMNI_GLOBAL_QPS="5.0"

# [ZH] 超时后的最大重试次数。默认值：3
# [EN] Max retry count after timeout. Default: 3
TIKOMNI_TIMEOUT_RETRY_MAX="3"

# [ZH] 超时重试退避，单位毫秒。默认值：300
# [EN] Timeout retry backoff in milliseconds. Default: 300
TIKOMNI_TIMEOUT_RETRY_BACKOFF_MS="300"

# [ZH] 显式配置文件路径。默认值：空；留空时自动使用本模块 defaults.yaml
# [EN] Explicit config file path. Default: empty; when empty the module uses its own defaults.yaml
# TIKOMNI_CONFIG_FILE=""
