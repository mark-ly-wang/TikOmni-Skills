# TikOmni Skill Environment Template / 环境变量模板
# Copy to <workspace_root>/.env or skills/tikomni-skill/.env.local / 复制到上述路径之一
# Replace placeholders with real values / 将示例值替换为真实值
# Never commit real secrets / 不要提交真实密钥
# Optional vars below are commented out by default.
# To enable one: remove leading "# " and set a value.
# 下方可选变量默认被注释；要启用某项：去掉行首 "# " 并填写值。

# ============================
# Required (must set) / 必填项
# ============================
TIKOMNI_API_KEY="tk_example_replace_me"
# Required absolute path / 必填绝对路径
# Used for runner outputs (_runs/results/_errors) / 用于运行输出（_runs/results/_errors）
TIKOMNI_OUTPUT_ROOT="/absolute/path/to/tikomni-output"
# Card root absolute path (required for fixed pipelines because card writing is mandatory)
# 卡片根目录绝对路径（固定 pipeline 强制写卡，因此为必填）
TIKOMNI_CARD_ROOT="/absolute/path/to/tikomni-cards"

# ====================================================
# Optional Advanced / 高级可选
# Enable by uncommenting / 启用请去掉行首 "# "
# ====================================================

# Request timeout in milliseconds (default: 60000) / 请求超时（毫秒）
# TIKOMNI_TIMEOUT_MS="60000"

# Output subdirectories under TIKOMNI_OUTPUT_ROOT / 输出根目录下的子目录
# Affects runner markdown/json outputs, not card routing / 影响运行输出文件，不影响卡片路由
# Defaults: _runs / results / _errors
# 默认值：_runs / results / _errors
# TIKOMNI_OUTPUT_RUNS_DIR="_runs"
# TIKOMNI_OUTPUT_RESULTS_DIR="results"
# TIKOMNI_OUTPUT_ERRORS_DIR="_errors"

# Filename pattern for non-card outputs / 非卡片输出文件命名模板
# Default: {type}-{timestamp}-{job_id}.md / 默认值如上
# TIKOMNI_FILENAME_PATTERN="{type}-{timestamp}-{job_id}.md"

# Route locale preset for card directories: zh | en (default: zh)
# 卡片目录语言预设：zh | en（默认：zh）
# TIKOMNI_PATH_LOCALE="zh"

# Explicit card routes (highest priority; use "|" as separator)
# Fixed pipelines always write cards under TIKOMNI_CARD_ROOT using these routes when configured
# 显式卡片路由（最高优先级；固定 pipeline 始终写卡，配置后落到 TIKOMNI_CARD_ROOT 下）
# TIKOMNI_CARD_ROUTE_WORK="content-system|benchmark|work-cards"
# TIKOMNI_CARD_ROUTE_AUTHOR="content-system|benchmark|author-cards"
# TIKOMNI_CARD_ROUTE_AUTHOR_SAMPLE_WORK="content-system|benchmark|author-samples|{platform}-{author_slug}"

# Optional HTTP header overrides / 可选 HTTP 头覆盖（一般不需要）
# TIKOMNI_HTTP_USER_AGENT="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/123.0.0.0 Safari/537.36"
# TIKOMNI_HTTP_ACCEPT_LANGUAGE="zh-CN,zh;q=0.9,en;q=0.8"
